# Ethiack Beacon - environment configuration
# Managed by Ansible. Do not edit manually.

# ── Required ──────────────────────────────────────────────────────────────────
ETHIACK_API_KEY={{ ethiack_api_key }}
ETHIACK_API_SECRET={{ ethiack_api_secret }}

# ── API ───────────────────────────────────────────────────────────────────────
ETHIACK_API_URL={{ ethiack_api_url }}

# ── Beacon identity ───────────────────────────────────────────────────────────
ETHIACK_BEACON_NAME={{ ethiack_beacon_name }}
{% if ethiack_beacon_cidrs | default('') | length > 0 %}
ETHIACK_BEACON_CIDRS={{ ethiack_beacon_cidrs }}
{% endif %}

# ── Optional ──────────────────────────────────────────────────────────────────
# ETHIACK_ASSUME_DETECTED_CIDRS is only needed when the beacon resolves CIDRs
# itself at runtime. When running inside Docker (no host networking), CIDRs are
# detected on the host by Ansible and passed explicitly via ETHIACK_BEACON_CIDRS.
{% if ethiack_assume_detected_cidrs | default(false) and (ethiack_beacon_cidrs | default('') | length == 0) %}
ETHIACK_ASSUME_DETECTED_CIDRS=1
{% else %}
# ETHIACK_ASSUME_DETECTED_CIDRS=1
{% endif %}

{% if ethiack_create_pentest | default(true) %}
ETHIACK_CREATE_PENTEST=true
{% else %}
ETHIACK_CREATE_PENTEST=false
{% endif %}
{% if ethiack_pentest_slug %}
ETHIACK_PENTEST_SLUG={{ ethiack_pentest_slug }}
{% else %}
# ETHIACK_PENTEST_SLUG=
{% endif %}
# Set to skip all pentest configuration (ignores ETHIACK_CREATE_PENTEST and ETHIACK_PENTEST_SLUG).
{% if ethiack_skip_pentest_config | default(false) %}
ETHIACK_SKIP_PENTEST_CONFIG=1
{% else %}
# ETHIACK_SKIP_PENTEST_CONFIG=1
{% endif %}

ETHIACK_BEACON_HEALTH_INTERVAL={{ ethiack_beacon_health_interval }}
