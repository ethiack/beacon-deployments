# Ethiack Beacon — environment configuration
# Managed by Ansible. Do not edit manually.

# ── Required ──────────────────────────────────────────────────────────────────
ETHIACK_API_KEY={{ ethiack_api_key }}
ETHIACK_API_SECRET={{ ethiack_api_secret }}

# ── API ───────────────────────────────────────────────────────────────────────
ETHIACK_API_URL={{ ethiack_api_url }}

# ── Beacon identity ───────────────────────────────────────────────────────────
ETHIACK_BEACON_NAME={{ ethiack_beacon_name }}
{% if ethiack_beacon_cidrs | default('') | length > 0 %}
ETHIACK_BEACON_CIDRS={{ ethiack_beacon_cidrs }}
{% endif %}

# ── Optional ──────────────────────────────────────────────────────────────────
# Auto-detect CIDRs from the host's network interfaces instead of requiring
# ETHIACK_BEACON_CIDRS. Set to any non-empty value to enable.
{% if ethiack_assume_detected_cidrs | default(false) %}
ETHIACK_ASSUME_DETECTED_CIDRS=1
{% else %}
# ETHIACK_ASSUME_DETECTED_CIDRS=1
{% endif %}

{% if ethiack_pentest_slug %}
ETHIACK_PENTEST_SLUG={{ ethiack_pentest_slug }}
{% else %}
# ETHIACK_PENTEST_SLUG=
{% endif %}
# Set to skip the pentest slug prompt (and ignore ETHIACK_PENTEST_SLUG).
{% if ethiack_skip_pentest_slug | default(false) %}
ETHIACK_SKIP_PENTEST_SLUG=1
{% else %}
# ETHIACK_SKIP_PENTEST_SLUG=1
{% endif %}

ETHIACK_BEACON_HEALTH_INTERVAL={{ ethiack_beacon_health_interval }}
